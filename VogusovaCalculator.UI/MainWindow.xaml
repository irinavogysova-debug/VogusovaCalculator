<Window x:Class="VogusovaCalculator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:VogusovaCalculator.UI.ViewModels"
        Title="Калькулятор Вогусовой" 
        Height="500" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="450"
        MinWidth="350"
        Background="DimGray">

    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD966"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EqualsButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="ClearButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FF6B6B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#4682B4" BorderThickness="2" CornerRadius="5" Margin="0,0,0,10" Padding="5">
            <TextBox Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="32" 
                     FontFamily="Consolas"
                     FontWeight="Bold"
                     Margin="5"
                     Padding="10"
                     IsReadOnly="True" 
                     TextAlignment="Right"
                     Background="LightGray"
                     BorderBrush="#CCCCCC"
                     BorderThickness="1"
                     MinHeight="60"/>
        </Border>

        <UniformGrid Grid.Row="1" Rows="5" Columns="4" Margin="0,0,0,10">

            <!-- 1-й ряд: скобки, степень, деление -->
            <Button Content="(" Command="{Binding DigitCommand}" CommandParameter="("/>
            <Button Content=")" Command="{Binding DigitCommand}" CommandParameter=")"/>
            
            <Button Content="^" Command="{Binding OperationCommand}" CommandParameter="Power"/>
            
            <Button Content="÷" Command="{Binding OperationCommand}" CommandParameter="Divide"/>

            <!-- 2-й ряд: 7,8,9, умножение -->
            <Button Content="7" Command="{Binding DigitCommand}" CommandParameter="7"/>
            <Button Content="8" Command="{Binding DigitCommand}" CommandParameter="8"/>
            <Button Content="9" Command="{Binding DigitCommand}" CommandParameter="9"/>
            
            <Button Content="×" Command="{Binding OperationCommand}" CommandParameter="Multiply"/>

            <!-- 3-й ряд: 4,5,6, вычитание -->
            <Button Content="4" Command="{Binding DigitCommand}" CommandParameter="4"/>
            <Button Content="5" Command="{Binding DigitCommand}" CommandParameter="5"/>
            <Button Content="6" Command="{Binding DigitCommand}" CommandParameter="6"/>
            
            <Button Content="-" Command="{Binding OperationCommand}" CommandParameter="Subtract"/>

            <!-- 4-й ряд: 1,2,3, сложение -->
            <Button Content="1" Command="{Binding DigitCommand}" CommandParameter="1"/>
            <Button Content="2" Command="{Binding DigitCommand}" CommandParameter="2"/>
            <Button Content="3" Command="{Binding DigitCommand}" CommandParameter="3"/>
            
            <Button Content="+" Command="{Binding OperationCommand}" CommandParameter="Add"/>

            <!-- 5-й ряд: 0, точка, C, равно -->
            <Button Content="0" Command="{Binding DigitCommand}" CommandParameter="0"/>
            <Button Content="." Command="{Binding DigitCommand}" CommandParameter="."/>
            <Button Content="C" Style="{StaticResource ClearButtonStyle}" Command="{Binding ClearCommand}"/>
            <Button Content="=" Style="{StaticResource EqualsButtonStyle}" Command="{Binding EqualsCommand}"/>
        </UniformGrid>

        <GroupBox Grid.Row="2" Header="История вычислений" BorderBrush="DimGray">
            <ListBox ItemsSource="{Binding History}" 
                     Height="100"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="11"
                     Background="LightGray"/>
        </GroupBox>
    </Grid>
</Window>